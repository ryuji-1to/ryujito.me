    "postcss": "^8",
    "shiki": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
