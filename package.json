    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "rustlike-ts": "^1.1.0",
    "tailwind-merge": "^3.0.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@markuplint/jsx-parser": "^4.7.22",
    "@markuplint/react-spec": "^4.5.22",
    "@shikijs/markdown-it": "^3.2.2",
